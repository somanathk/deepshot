{
  "manifest_version": 3,
  "name": "DeepShot",
  "version": "1.1",
  "description": "Captures full-page screenshots of nested scrollables, with PDF and Markdown export (tables & grids preserved).",
  "author": "Somanath Reddy",
  "homepage_url": "https://github.com/somanathk/deepshot",
  "permissions": ["activeTab", "scripting", "downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
